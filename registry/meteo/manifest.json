{
  "manifest_version": 1,
  "id": "meteo",
  "name": "Météo",
  "version": "0.22.0",
  "kiosk_api": "^1.3",
  "author": "The Worm's",
  "type": "code",
  "category": "Quotidien",
  "tiles": [
    {
      "name": "Météo",
      "icon": "🌤️",
      "source": "météo",
      "color": "#2dd4bf",
      "category": "meteo",
      "fleet": false,
      "default_installed": true,
      "default_rank": 10
    }
  ],
  "config": {
    "fields": [
      {
        "key": "geo",
        "label": "Localisation automatique",
        "type": "toggle",
        "default": true
      },
      {
        "key": "ville",
        "label": "Ville"
      },
      {
        "key": "lat",
        "label": "Latitude",
        "type": "number"
      },
      {
        "key": "lon",
        "label": "Longitude",
        "type": "number"
      },
      {
        "key": "dept",
        "label": "Département (Vigilance Météo-France)",
        "placeholder": "56"
      },
      {
        "key": "pack",
        "label": "Pack d'icônes",
        "type": "select",
        "default": "meteocons",
        "options": [
          [
            "meteocons",
            "Meteocons (par défaut)"
          ],
          [
            "weathericon",
            "WeatherIcon"
          ],
          [
            "colorline",
            "Color line"
          ],
          [
            "meteoicons",
            "Meteo Icons"
          ],
          [
            "weathericonic",
            "Weather Iconic"
          ],
          [
            "makinthings",
            "Weather Icons"
          ]
        ]
      }
    ]
  },
  "backend": {
    "entry": "backend.py"
  },
  "permissions": {
    "network": [
      "api.open-meteo.com",
      "geocoding-api.open-meteo.com",
      "air-quality-api.open-meteo.com",
      "webservice.meteofrance.com"
    ]
  },
  "ui": {
    "entry": "ui.js",
    "background": true
  },
  "logo": "logo.svg"
}