{
  "manifest_version": 1,
  "id": "lune",
  "name": "Lune",
  "version": "0.20.0",
  "kiosk_api": "^1.3",
  "author": "The Worm's",
  "type": "code",
  "category": "Quotidien",
  "tiles": [
    {
      "name": "Lune",
      "icon": "🌙",
      "source": "imcce + calcul local",
      "color": "#c98af0",
      "category": "meteo",
      "fleet": false
    }
  ],
  "config": {
    "fields": [
      {
        "key": "ville",
        "label": "Ville",
        "type": "text",
        "placeholder": "Saint-Malo"
      },
      {
        "key": "lat",
        "label": "Latitude",
        "type": "number"
      },
      {
        "key": "lon",
        "label": "Longitude",
        "type": "number"
      }
    ]
  },
  "backend": {
    "entry": "backend.py"
  },
  "permissions": {
    "network": [
      "opale.imcce.fr",
      "geocoding-api.open-meteo.com"
    ]
  },
  "ui": {
    "entry": "ui.js"
  }
}