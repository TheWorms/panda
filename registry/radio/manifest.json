{
  "manifest_version": 1,
  "id": "radio",
  "name": "Radio",
  "version": "0.11.0",
  "kiosk_api": "^1.3",
  "author": "The Worm's",
  "type": "code",
  "category": "Médias",
  "tiles": [
    {
      "name": "Radio",
      "icon": "📻",
      "source": "radio-browser",
      "color": "#e8635a",
      "category": "media",
      "fleet": false
    }
  ],
  "config": {
    "fields": [
      {
        "key": "country",
        "label": "Pays",
        "placeholder": "France"
      },
      {
        "key": "tag",
        "label": "Genre par défaut (optionnel)",
        "placeholder": "jazz, news, rock…"
      }
    ]
  },
  "backend": {
    "entry": "backend.py"
  },
  "permissions": {
    "network": [
      "https://de1.api.radio-browser.info"
    ]
  },
  "ui": {
    "entry": "ui.js",
    "background": true
  }
}